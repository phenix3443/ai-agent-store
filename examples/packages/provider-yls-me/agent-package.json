{
  "schemaVersion": 1,
  "name": "yls-me-provider",
  "displayName": "yls-me Provider",
  "version": "1.0.0",
  "description": "Provider package for yls-me Codex endpoint",
  "publisher": {
    "slug": "local",
    "name": "Local"
  },
  "categories": ["provider"],
  "keywords": ["provider", "yls", "codex"],
  "components": [
    {
      "id": "yls-me",
      "type": "provider",
      "version": "1.0.0",
      "configSchema": {
        "type": "object",
        "required": ["apiKey", "baseUrl"],
        "properties": {
          "apiKey": {
            "type": "string",
            "x-agent-secret": true
          },
          "baseUrl": {
            "type": "string",
            "default": "https://code.ylsagi.com/codex"
          }
        }
      },
      "provider": {
        "baseUrlKey": "baseUrl"
      },
      "models": ["gpt-5.4"],
      "targets": {
        "claude": true,
        "codex": true
      }
    }
  ]
}
