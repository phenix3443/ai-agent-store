# Neon Auth (managed Better Auth) — store auth. base_url from the Neon
# dashboard (project → Auth); cookie secret is any random string ≥32 chars
# (e.g. `openssl rand -hex 32`). Server-only (no NEXT_PUBLIC_).
NEON_AUTH_BASE_URL="https://<endpoint>.neonauth.<region>.aws.neon.tech/<db>/auth"
NEON_AUTH_COOKIE_SECRET="<random-32+-char-secret>"
NEXT_PUBLIC_API_URL="https://as-api-test.<subdomain>.workers.dev"
