{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent-store-web",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  // Two named environments; CI always deploys with `--env`:
  //   dev  branch → `wrangler deploy --env test`        (test.agent-store.panghuli.tech → test API)
  //   main branch → `wrangler deploy --env production`  (agent-store.panghuli.tech      → prod API)
  // `routes` and `vars` are non-inheritable, so each env repeats them. `API_URL`
  // is the server-side (SSR) catalog endpoint; the browser-side NEXT_PUBLIC_API_URL
  // is baked at build time by deploy-store.yml.
  "env": {
    "production": {
      "name": "agent-store-web",
      "routes": [{ "pattern": "agent-store.panghuli.tech", "custom_domain": true }],
      "vars": {
        "API_URL": "https://as-api.phenix3443.workers.dev"
      }
    },
    "test": {
      "name": "agent-store-web-test",
      "routes": [{ "pattern": "test.agent-store.panghuli.tech", "custom_domain": true }],
      "vars": {
        "API_URL": "https://as-api-test.phenix3443.workers.dev"
      }
    }
  }
}
