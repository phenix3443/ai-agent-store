{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Agent Store CLI",
  "version": "0.1.0",
  "identifier": "com.aas.cli-gui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5183",
    "beforeDevCommand": "pnpm dev"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Store CLI",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/aas"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
