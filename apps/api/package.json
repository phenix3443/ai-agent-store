{
  "name": "@as/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist *.tsbuildinfo",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun --env-file=.dev.vars drizzle-kit migrate"
  },
  "dependencies": {
    "@as/types": "workspace:*",
    "@neondatabase/serverless": "^1.0.1",
    "@waffo/pancake-ts": "^0.11.0",
    "drizzle-orm": "^0.44.5",
    "hono": "^4.6.0",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.5",
    "typescript": "^5.4.0",
    "wrangler": "^4.107.0"
  }
}
